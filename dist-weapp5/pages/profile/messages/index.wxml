<view class="min-h-screen bg-orange-50 p-4">
  <view class="flex items-center justify-between mb-4">
    <text class="text-xl font-bold text-stone-900">互动消息</text>
    <text wx:if="{{messages.length > 0}}" class="text-sm text-stone-500" bindtap="clearAll">清空</text>
  </view>
  
  <view wx:if="{{messages.length === 0}}" class="flex flex-col items-center justify-center py-20">
    <text class="text-stone-400 text-base">暂无消息</text>
  </view>
  
  <view wx:for="{{messages}}" wx:key="id" class="bg-white rounded-xl shadow-sm mb-3" bindtap="markAsRead" data-id="{{item.id}}">
    <view class="p-4 flex items-start gap-3">
      <view wx:if="{{!item.read}}" class="w-2 h-2 bg-red-600 rounded-full mt-2 flex-shrink-0"></view>
      <view wx:else class="w-2 h-2 bg-transparent rounded-full mt-2 flex-shrink-0"></view>
      <view class="flex-1">
        <text class="block text-sm text-stone-700 mb-1">{{item.content}}</text>
        <text class="block text-xs text-stone-400">{{item.time}}</text>
      </view>
      <view bindtap="deleteMessage" data-id="{{item.id}}" catchtap>
        <text class="text-stone-400 text-lg">×</text>
      </view>
    </view>
  </view>
</view>

page {
  background: #fef7ed;
}

.page-container {
  padding: 24rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.page-header {
  margin-bottom: 24rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1c1917;
}

.page-sub {
  display: block;
  font-size: 24rpx;
  color: #a8a29e;
  margin-top: 8rpx;
}

.empty-box {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  color: #a8a29e;
  font-size: 28rpx;
}

.work-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.work-img {
  width: 100%;
  height: 360rpx;
  background: #f5f5f4;
}

.work-body {
  padding: 24rpx;
}

.work-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #1c1917;
}

.work-author {
  display: block;
  font-size: 26rpx;
  color: #78716c;
  margin-top: 8rpx;
}

.work-meta {
  display: flex;
  gap: 24rpx;
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #57534e;
}

.btn-row {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.btn-outline,
.btn-warn {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  border-radius: 12rpx;
  font-size: 26rpx;
}

.btn-outline {
  border: 1rpx solid #d6d3d1;
  color: #57534e;
}

.btn-warn {
  border: 1rpx solid #fcd34d;
  color: #b45309;
  background: #fffbeb;
}

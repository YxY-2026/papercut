.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.search-box {
  margin-bottom: 20rpx;
}
.search-input {
  height: 70rpx;
  background: #fff;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.work-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.work-item {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.work-img {
  width: 100%;
  height: 400rpx;
}

.work-info {
  padding: 20rpx;
}

.work-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
  color: #333;
}

.work-author {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.follow-btn {
  background: #ff6b6b;
  color: #fff;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  margin-bottom: 16rpx;
  border: none;
}
.follow-btn.followed {
  background: #999;
  color: #fff;
}

.work-actions {
  display: flex;
  gap: 30rpx;
}

.action-item {
  font-size: 26rpx;
}

.like-btn {
  color: #999;
}
.like-btn.liked {
  color: #ff4757;
}

.collect-btn {
  color: #999;
}
.collect-btn.collected {
  color: #ffa502;
}
page {
  background: #fef7ed;
}
.page {
  min-height: 100vh;
  padding-bottom: 40rpx;
}
.top-bar {
  padding: 24rpx;
}
.back {
  font-size: 32rpx;
  color: #c8161d;
}
.cover {
  width: 100%;
  background: #fff;
}
.body {
  padding: 32rpx;
}
.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1c1917;
  margin-bottom: 16rpx;
}
.subtitle {
  display: block;
  font-size: 28rpx;
  color: #78716c;
  margin-bottom: 24rpx;
}
.content {
  display: block;
  font-size: 30rpx;
  line-height: 1.7;
  color: #44403c;
}
.btn {
  margin-top: 48rpx;
  background: #c8161d;
  color: #fff;
  border-radius: 48rpx;
}

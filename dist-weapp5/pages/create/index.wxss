/* 页面容器 */
.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #f5f0e8 0%, #e8dfd0 100%);
  padding: 0;
  box-sizing: border-box;
}

/* 角数选择器 */
.fold-selector {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-bottom: 1rpx solid #e0d5c5;
}

.fold-btn {
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  background: #f5f0e8;
  color: #666;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.fold-btn.active {
  background: #8B0000;
  color: #fff;
  border-color: #8B0000;
}

/* 画布区域 */
.canvas-area {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx;
  position: relative;
}

.paper-canvas {
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 30rpx rgba(139, 0, 0, 0.3);
}

/* 工具栏 */
.toolbar {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 10rpx;
  background: #fff;
  border-top: 1rpx solid #e0d5c5;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tool-btn {
  padding: 12rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #555;
  background: #f8f5f0;
  min-width: 80rpx;
  text-align: center;
  transition: all 0.2s;
}

.tool-btn:active {
  transform: scale(0.95);
}

.tool-btn.active {
  background: #8B0000;
  color: #fff;
}

.tool-btn[disabled] {
  opacity: 0.4;
}

/* 底部操作栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
}

.action-btn {
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.expand-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(238, 90, 90, 0.4);
}

.save-btn {
  background: linear-gradient(135deg, #4ecdc4 0%, #44a08d 100%);
  color: #fff;
  box-shadow: 0 6rpx 20rpx rgba(68, 160, 141, 0.4);
}

/* 弹窗遮罩 */
.dialog-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 10000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.dialog-overlay.show {
  opacity: 1;
  pointer-events: auto;
}

/* 弹窗 */
.dialog {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  width: 80%;
  max-width: 600rpx;
  transform: scale(0.8);
  transition: transform 0.3s;
}

.dialog-overlay.show .dialog {
  transform: scale(1);
}

.dialog-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
}

.dialog-content {
  margin-bottom: 40rpx;
}

.dialog-btns {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.dialog-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  text-align: center;
}

.dialog-btn.cancel {
  background: #f0f0f0;
  color: #666;
}

.dialog-btn.confirm {
  background: #8B0000;
  color: #fff;
}

/* 设置项 */
.setting-item {
  margin-bottom: 30rpx;
}

.setting-item text {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
}

/* 颜色选择器 */
.color-picker {
  display: flex;
  gap: 30rpx;
  justify-content: center;
}

.color-opt {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  transition: transform 0.2s;
}

.color-opt:active {
  transform: scale(0.9);
}

.color-opt.active {
  box-shadow: 0 0 0 6rpx #fff, 0 0 0 10rpx #8B0000;
}

/* 预览画布 */
.expand-dialog {
  width: 90%;
  max-width: 750rpx;
}

.preview-canvas {
  width: 500rpx;
  height: 500rpx;
  margin: 0 auto;
  display: block;
  border-radius: 50%;
}

/* Toast提示 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.8);
  background: rgba(0, 0, 0, 0.75);
  color: #fff;
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  z-index: 2000;
  opacity: 0;
  pointer-events: none;
  transition: all 0.3s;
}

.toast.show {
  opacity: 1;
  transform: translate(-50%, -50%) scale(1);
}

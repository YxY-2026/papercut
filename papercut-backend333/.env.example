# 小程序可访问的后端地址（改为你电脑的局域网 IP，端口 8001）
PUBLIC_BASE_URL=http://10.122.252.164:8001

# 即梦 AI 密钥配置
JIMENG_ACCESS_KEY=your_access_key
JIMENG_SECRET_KEY=your_secret_key
JIMENG_REQ_KEY=your_req_key
JIMENG_API_KEY=your_bearer_token

# 阿里云 COS 配置（可选）
ALI_CLOUD_ACCESS_KEY_ID=your_ali_key_id
ALI_CLOUD_ACCESS_KEY_SECRET=your_ali_key_secret
ALI_CLOUD_BUCKET_NAME=your_bucket
ALI_CLOUD_ENDPOINT=your_endpoint
ALI_CLOUD_REGION=your_region
